{
  "name": "@textbubbles/js",
  "version": "0.3.0",
  "description": "TypeScript SDK for the TextBubbles messaging API",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./webhooks": {
      "import": {
        "types": "./dist/esm/webhooks.d.ts",
        "default": "./dist/esm/webhooks.js"
      },
      "require": {
        "types": "./dist/cjs/webhooks.d.ts",
        "default": "./dist/cjs/webhooks.js"
      }
    },
    "./nextjs": {
      "import": {
        "types": "./dist/esm/nextjs.d.ts",
        "default": "./dist/esm/nextjs.js"
      },
      "require": {
        "types": "./dist/cjs/nextjs.d.ts",
        "default": "./dist/cjs/nextjs.js"
      }
    },
    "./events": {
      "import": {
        "types": "./dist/esm/events.d.ts",
        "default": "./dist/esm/events.js"
      },
      "require": {
        "types": "./dist/cjs/events.d.ts",
        "default": "./dist/cjs/events.js"
      }
    }
  },
  "bin": {
    "textbubbles": "./dist/cjs/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "textbubbles",
    "messaging",
    "imessage",
    "sms",
    "sdk",
    "api"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "ora": "^5.4.1"
  }
}
